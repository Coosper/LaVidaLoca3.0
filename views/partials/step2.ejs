<section id="step2"
    class="relative bg-step2-background border-dotted border-step2-border border-4 shadow-xl rounded-lg p-6 mt-16 mb-8 mx-4 md:mx-8 lg:mx-16 font-family-brandon">
    <div
        class="absolute -top-10 left-1/2 -translate-x-1/2 bg-step2-border text-menu-background font-family-custom px-4 py-2 uppercase shadow-xl w-[350px] md:w-[450px] flex items-center justify-center text-3xl md:text-4xl rotate-[358deg]">
        🌯 Step 2: Choose Your Dish
    </div>

    <div class="mt-10 flex flex-col lg:flex-row gap-8">

        <!-- Traditional Mexican Section -->
        <div class="flex-1">
            <h3 class="text-3xl font-bold text-step2-border mb-3 flex items-center gap-2">
                Traditional Mexican
                <img src="/images/GF.ico" class="inline-block h-6 w-6" alt="Gluten Free">
            </h3>
            <p class="text-gray-600 text-sm mb-6 italic">
                <%= menu.step2_dishes.traditional_mexican[0].sides_included %>
            </p>

            <ul class="space-y-5">
                <% menu.step2_dishes.traditional_mexican.forEach(function(dish) { %>
                    <li class="flex items-start menu-item">
                        <span class="text-step2-border mr-2 text-2xl">
                            <% if (dish.name.includes('Taco')) { %>🌮
                                <% } else if (dish.name.includes('Tostada')) { %>🥙
                                    <% } else if (dish.name.includes('Quesadilla')) { %>🧀
                                        <% } else { %>🌮<% } %>
                        </span>
                        <div class="flex justify-between w-full">
                            <div class="flex-1">
                                <p class="text-step2-border font-bold text-lg flex items-center gap-2">
                                    <%= dish.name %>
                                        <% if (dish.dietary && dish.dietary.gluten_free===true) { %>
                                            <img src="/images/GF.ico" class="inline-block h-5 w-5" alt="Gluten Free">
                                            <% } %>
                                </p>
                                <p class="text-gray-700 text-sm">
                                    <%= dish.description %>
                                </p>
                                <div class="flex gap-2 mt-1 flex-wrap">
                                    <% if (dish.allergens && dish.allergens.length> 0) { %>
                                        <span
                                            class="text-[10px] bg-step2-background text-step2-border border border-step2-border px-1.5 py-0.5 rounded-full">
                                            (<%= dish.allergens.join(', ') %>)
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                            <p class="text-step2-border font-bold text-xl ml-4">€<%= dish.price %></p>
                        </div>
                    </li>
                <% }); %>
            </ul>
        </div>

        <!-- Divider (horizontal on mobile) -->
        <div class="lg:hidden my-8 flex items-center">
            <div class="flex-1 border-t-2 border-step2-border border-dotted"></div>
            <span class="px-4 text-step2-border font-bold text-xl">✦</span>
            <div class="flex-1 border-t-2 border-step2-border border-dotted"></div>
        </div>

        <!-- Divider (vertical on large screens) -->
        <div class="hidden lg:flex lg:flex-col lg:items-center lg:justify-center lg:mx-4">
            <div class="flex-1 border-l-2 border-step2-border border-dotted"></div>
            <span class="py-4 text-step2-border font-bold text-2xl">✦</span>
            <div class="flex-1 border-l-2 border-step2-border border-dotted"></div>
        </div>

        <!-- Loaded Tex-Mex Section -->
        <div class="flex-1">
            <h3 class="text-3xl font-bold text-step2-border mb-6">Loaded Tex-Mex Dishes</h3>
            
            <ul class="space-y-5">
                <% menu.step2_dishes.loaded_tex_mex.forEach(function(dish) { %>
                    <li class="flex items-start menu-item">
                        <span class="text-step2-border mr-2 text-2xl">🌯</span>
                        <div class="flex justify-between w-full">
                            <div class="flex-1">
                                <p class="text-step2-border font-bold text-lg flex items-center gap-2">
                                    <%= dish.name %>
                                    <% if (dish.dietary && dish.dietary.gluten_free === true) { %>
                                        <img src="/images/GF.ico" class="inline-block h-5 w-5" alt="Gluten Free">
                                    <% } %>
                                </p>
                                <p class="text-gray-700 text-sm"><%= dish.description %></p>
                                <div class="flex gap-2 mt-1 flex-wrap">
                                    <% if (dish.allergens && dish.allergens.length > 0) { %>
                                        <span class="text-[10px] bg-step2-background text-step2-border border border-step2-border px-1.5 py-0.5 rounded-full">
                                            (<%= dish.allergens.join(' , ') %>)
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                            <p class="text-step2-border font-bold text-xl ml-4">€<%= dish.price %></p>
                        </div>
                    </li>
                <% }); %>
            </ul>
        </div>
        
    </div>
    
</section>